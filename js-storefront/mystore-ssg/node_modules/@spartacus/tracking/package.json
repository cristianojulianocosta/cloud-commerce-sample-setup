{
    "name": "@spartacus/tracking",
    "version": "2211.21.0",
    "description": "Spartacus tracking and personalization library",
    "keywords": [
        "spartacus",
        "framework",
        "storefront",
        "tracking",
        "tms",
        "adobe launch",
        "gtm",
        "personalization"
    ],
    "homepage": "https://github.com/SAP/spartacus",
    "repository": "https://github.com/SAP/spartacus/tree/develop/feature-libs/tracking",
    "license": "Apache-2.0",
    "dependencies": {
        "tslib": "^2.6.2"
    },
    "peerDependencies": {
        "@angular-devkit/schematics": "^17.0.5",
        "@angular/common": "^17.0.5",
        "@angular/core": "^17.0.5",
        "@spartacus/core": "2211.21.0",
        "@spartacus/schematics": "2211.21.0",
        "rxjs": "^7.8.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "schematics": "./schematics/collection.json",
    "module": "fesm2022/spartacus-tracking.mjs",
    "typings": "index.d.ts",
    "exports": {
        "./package.json": {
            "default": "./package.json"
        },
        ".": {
            "types": "./index.d.ts",
            "esm2022": "./esm2022/spartacus-tracking.mjs",
            "esm": "./esm2022/spartacus-tracking.mjs",
            "default": "./fesm2022/spartacus-tracking.mjs"
        },
        "./personalization": {
            "types": "./personalization/index.d.ts",
            "esm2022": "./esm2022/personalization/spartacus-tracking-personalization.mjs",
            "esm": "./esm2022/personalization/spartacus-tracking-personalization.mjs",
            "default": "./fesm2022/spartacus-tracking-personalization.mjs"
        },
        "./tms": {
            "types": "./tms/index.d.ts",
            "esm2022": "./esm2022/tms/spartacus-tracking-tms.mjs",
            "esm": "./esm2022/tms/spartacus-tracking-tms.mjs",
            "default": "./fesm2022/spartacus-tracking-tms.mjs"
        },
        "./personalization/core": {
            "types": "./personalization/core/index.d.ts",
            "esm2022": "./esm2022/personalization/core/spartacus-tracking-personalization-core.mjs",
            "esm": "./esm2022/personalization/core/spartacus-tracking-personalization-core.mjs",
            "default": "./fesm2022/spartacus-tracking-personalization-core.mjs"
        },
        "./personalization/root": {
            "types": "./personalization/root/index.d.ts",
            "esm2022": "./esm2022/personalization/root/spartacus-tracking-personalization-root.mjs",
            "esm": "./esm2022/personalization/root/spartacus-tracking-personalization-root.mjs",
            "default": "./fesm2022/spartacus-tracking-personalization-root.mjs"
        },
        "./tms/aep": {
            "types": "./tms/aep/index.d.ts",
            "esm2022": "./esm2022/tms/aep/spartacus-tracking-tms-aep.mjs",
            "esm": "./esm2022/tms/aep/spartacus-tracking-tms-aep.mjs",
            "default": "./fesm2022/spartacus-tracking-tms-aep.mjs"
        },
        "./tms/core": {
            "types": "./tms/core/index.d.ts",
            "esm2022": "./esm2022/tms/core/spartacus-tracking-tms-core.mjs",
            "esm": "./esm2022/tms/core/spartacus-tracking-tms-core.mjs",
            "default": "./fesm2022/spartacus-tracking-tms-core.mjs"
        },
        "./tms/gtm": {
            "types": "./tms/gtm/index.d.ts",
            "esm2022": "./esm2022/tms/gtm/spartacus-tracking-tms-gtm.mjs",
            "esm": "./esm2022/tms/gtm/spartacus-tracking-tms-gtm.mjs",
            "default": "./fesm2022/spartacus-tracking-tms-gtm.mjs"
        }
    },
    "sideEffects": false
}