{
    "name": "@spartacus/smartedit",
    "version": "2211.21.0",
    "description": "Smart Edit feature library for Spartacus",
    "keywords": [
        "spartacus",
        "framework",
        "storefront",
        "smartedit"
    ],
    "homepage": "https://github.com/SAP/spartacus",
    "repository": "https://github.com/SAP/spartacus/tree/develop/feature-libs/smartedit",
    "license": "Apache-2.0",
    "dependencies": {
        "tslib": "^2.6.2"
    },
    "peerDependencies": {
        "@angular-devkit/schematics": "^17.0.5",
        "@angular/common": "^17.0.5",
        "@angular/core": "^17.0.5",
        "@spartacus/core": "2211.21.0",
        "@spartacus/schematics": "2211.21.0",
        "rxjs": "^7.8.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "schematics": "./schematics/collection.json",
    "module": "fesm2022/spartacus-smartedit.mjs",
    "typings": "index.d.ts",
    "exports": {
        "./package.json": {
            "default": "./package.json"
        },
        ".": {
            "types": "./index.d.ts",
            "esm2022": "./esm2022/spartacus-smartedit.mjs",
            "esm": "./esm2022/spartacus-smartedit.mjs",
            "default": "./fesm2022/spartacus-smartedit.mjs"
        },
        "./core": {
            "types": "./core/index.d.ts",
            "esm2022": "./esm2022/core/spartacus-smartedit-core.mjs",
            "esm": "./esm2022/core/spartacus-smartedit-core.mjs",
            "default": "./fesm2022/spartacus-smartedit-core.mjs"
        },
        "./root": {
            "types": "./root/index.d.ts",
            "esm2022": "./esm2022/root/spartacus-smartedit-root.mjs",
            "esm": "./esm2022/root/spartacus-smartedit-root.mjs",
            "default": "./fesm2022/spartacus-smartedit-root.mjs"
        }
    },
    "sideEffects": false
}